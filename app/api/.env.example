# ─────────────────────────────────────────────────────────────
# CEO Management Portal — API Environment Variables
# Copy to .env and fill in real values. Never commit .env.
# ─────────────────────────────────────────────────────────────

# API Server
PORT=3000
NODE_ENV=development

# JWT
JWT_SECRET=change_me_to_a_long_random_string
JWT_EXPIRES_IN=24h

# PostgreSQL (node-postgres / pg Pool)
DATABASE_URL=postgres://app:app@postgres:5432/ceo_portal

# Seed super-admin (CEO) — used by migrations/seed step
SEED_ADMIN_EMAIL=ceo@company.com
SEED_ADMIN_PASSWORD=change_me_on_first_run

# CMC Cloud S3 (S3-compatible)
S3_ENDPOINT=https://s3.cmccloud.vn
S3_REGION=hcm
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=ceo-reports

# beeknoee AI gateway (gemini-2.5-flash, OpenAI-compatible)
AI_BASE_URL=https://platform.beeknoee.com/api/v1
AI_API_KEY=
AI_MODEL=gemini-2.5-flash

# Gmail SMTP (Nodemailer)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
SMTP_FROM="CEO Portal <ceo@company.com>"

# App base URL — used to build report links in emails
APP_BASE_URL=http://localhost:3000

# Frontend (Vite)
VITE_API_BASE_URL=http://localhost:3000
