# ─────────────────────────────────────────────────────────────
# CEO Management Portal — Root .env.example
# Copy to .env and fill in real values. Never commit .env.
# Used by docker-compose (env_file: .env) and local dev.
# ─────────────────────────────────────────────────────────────

# ── API Server ────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ── JWT ───────────────────────────────────────────────────────
# Use: openssl rand -hex 64  to generate a strong secret.
JWT_SECRET=change_me_to_a_long_random_string_at_least_64_chars
JWT_EXPIRES_IN=24h

# ── PostgreSQL ────────────────────────────────────────────────
# These three vars are read by docker-compose to configure the postgres service
# AND are interpolated into DATABASE_URL below.
# POSTGRES_PASSWORD has no default — you MUST set it before running docker compose up.
POSTGRES_DB=ceo_portal
POSTGRES_USER=app
POSTGRES_PASSWORD=change_me
# Host port to expose the dockerized postgres. Default 5433 to avoid clashing with
# a postgres already running on the server's 5432. Does NOT affect the app (api
# connects via internal network "postgres":5432). Remove the postgres "ports:"
# block in docker-compose.yml if you don't need host access to the container DB.
POSTGRES_HOST_PORT=5782

# DATABASE_URL must stay consistent with the three vars above.
# In Docker Compose the host is the service name "postgres".
# For local dev (outside Docker) replace "postgres" with "localhost".
# Note: env_file does NOT expand shell variables — set this to a literal value
#       matching POSTGRES_USER / POSTGRES_PASSWORD / POSTGRES_DB above.
DATABASE_URL=postgres://app:change_me@postgres:5432/ceo_portal

# ── Seed super-admin (CEO) ────────────────────────────────────
# Created automatically by the migration seed step on first startup.
# Change SEED_ADMIN_PASSWORD before running in production.
SEED_ADMIN_EMAIL=ceo@company.com
SEED_ADMIN_PASSWORD=change_me_on_first_run

# ── CMC Cloud S3 (S3-compatible object storage) ──────────────
# Obtain credentials from CMC Cloud console.
S3_ENDPOINT=https://s3.cmccloud.vn
S3_REGION=hcm
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=ceo-reports

# ── beeknoee AI gateway (OpenAI-compatible, gemini-2.5-flash) ─
# Obtain API key from platform.beeknoee.com
AI_BASE_URL=https://platform.beeknoee.com/api/v1
AI_API_KEY=
AI_MODEL=gemini-2.5-flash

# ── Gmail SMTP (Nodemailer with App Password) ─────────────────
# SMTP_PASS must be a Gmail App Password (not your Google account password).
# Generate at: https://myaccount.google.com/apppasswords
# Requires 2FA enabled on the Gmail account.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your-sender@gmail.com
SMTP_PASS=xxxx-xxxx-xxxx-xxxx
SMTP_FROM="CEO Portal <your-sender@gmail.com>"

# ── Frontend (Vite build-time) ────────────────────────────────
# In Docker Compose the web service proxies /api → api:3000 via nginx,
# so VITE_API_BASE_URL is set to /api in docker-compose.yml build args
# and does NOT need to be set here for Docker deployments.
# For local dev (running `npm run dev` outside Docker):
VITE_API_BASE_URL=http://localhost:3000
